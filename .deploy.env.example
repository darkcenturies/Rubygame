# Copy to .deploy.env (never commit .deploy.env)
SFTP_HOST=sftp.shockbyte.fra1.shockbyte.host
SFTP_PORT=2222
SFTP_USER=your_username_from_shockbyte_sftp_connect_page
SFTP_PASSWORD=your_shockbyte_panel_password

# Remote target (same path you use in WinSCP). Default works for most Shockbyte servers.
REMOTE_PLUGINS_PATH=/Rubygame/plugins

# If deploy fails, open WinSCP, list the SFTP root, and match the folder name exactly, e.g.:
# REMOTE_PLUGINS_PATH=/1. Rubygame/plugins
